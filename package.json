{
  "name": "zimele-certification-tracker",
  "version": "1.0.0",
  "description": "Zimele Technologies SAP Certification Tracker",
  "scripts": {
    "start": "cds serve all --with-mocks --in-memory",
    "build": "mbt build",
    "watch": "cds watch"
  },
  "dependencies": {
    "@sap/cds": "^8",
    "@cap-js/hana": "^1",
    "@sap-cloud-sdk/http-client": "^3",
    "@sap-cloud-sdk/connectivity": "^3",
    "@sap-cloud-sdk/resilience": "^3"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^1",
    "@sap/cds-dk": "^8"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sql"
      }
    },
    "[production]": {
      "requires": {
        "db": {
          "kind": "hana-cloud"
        }
      }
    }
  }
}
