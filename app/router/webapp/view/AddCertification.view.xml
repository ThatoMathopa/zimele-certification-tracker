<mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.ui.layout.form"
  controllerName="zimele.certtracker.controller.AddCertification"
  displayBlock="true">

  <Page title="Add New Certification" showNavButton="true" navButtonPress="onNavBack"
        backgroundDesign="List">

    <footer>
      <Toolbar>
        <ToolbarSpacer/>
        <Button text="Save" type="Emphasized" press="onSave" icon="sap-icon://save"/>
        <Button text="Cancel" press="onNavBack" class="sapUiTinyMarginBegin"/>
      </Toolbar>
    </footer>

    <content>
      <VBox class="sapUiMediumMargin">
        <Panel headerText="Certification Details" expandable="false">
          <content>
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout"
                          labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                          columnsXL="2" columnsL="2" columnsM="1"
                          class="sapUiSmallMargin">
              <f:content>

                <Label text="Employee" required="true"/>
                <Select id="empSelect" width="100%" change="onEmployeeChange"
                        items="{
                          path: '/Employees',
                          parameters: { $orderby: 'firstName asc' },
                          filters: [{ path: 'isActive', operator: 'EQ', value1: true }]
                        }">
                  <items>
                    <core:Item xmlns:core="sap.ui.core"
                               key="{ID}" text="{firstName} {lastName} ({employeeId})"/>
                  </items>
                </Select>

                <Label text="Certification" required="true"/>
                <Select id="catalogSelect" width="100%" change="onCatalogChange"
                        items="{
                          path: '/CertificationCatalog',
                          parameters: { $orderby: 'certModule asc' },
                          filters: [{ path: 'isActive', operator: 'EQ', value1: true }]
                        }">
                  <items>
                    <core:Item xmlns:core="sap.ui.core"
                               key="{ID}" text="[{certModule}] {certName}"/>
                  </items>
                </Select>

                <Label text="Cert Code"/>
                <Input id="certCodeInput" value="{form>/certCode}" editable="false" width="100%"/>

                <Label text="Module"/>
                <Input id="certModuleInput" value="{form>/certModule}" editable="false" width="100%"/>

                <Label text="Issue Date" required="true"/>
                <DatePicker id="issueDatePicker" value="{form>/issueDate}"
                            valueFormat="yyyy-MM-dd" displayFormat="dd MMM yyyy"
                            change="onIssueDateChange" width="100%"/>

                <Label text="Expiry Date" required="true"/>
                <DatePicker id="expiryDatePicker" value="{form>/expiryDate}"
                            valueFormat="yyyy-MM-dd" displayFormat="dd MMM yyyy" width="100%"/>

                <Label text="Credly Badge URL"/>
                <Input id="credlyInput" value="{form>/credlyBadgeUrl}" width="100%"
                       placeholder="https://www.credly.com/badges/..."/>

                <Label text="Certificate Document URL"/>
                <Input id="proofInput" value="{form>/proofDocUrl}" width="100%"
                       placeholder="https://sharepoint.../certificate.pdf"/>

                <Label text="Verified By"/>
                <Input id="verifiedByInput" value="{form>/verifiedBy}" width="100%"
                       placeholder="Manager name"/>

                <Label text="Notes"/>
                <TextArea id="notesInput" value="{form>/notes}" width="100%"
                          rows="3" growing="true"/>

              </f:content>
            </f:SimpleForm>
          </content>
        </Panel>
      </VBox>
    </content>
  </Page>
</mvc:View>
